# --- GEMINI CONFIGURATION ---
# Get your API Key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- MCP SERVER TOKENS ---
# GitHub Token (Requires repo, workflow, read:org scopes)
# Get it at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# Slack Token (Optional: for Slack MCP)
SLACK_BOT_TOKEN=

# Google Maps API Key (Optional: for Maps MCP)
GOOGLE_MAPS_API_KEY=

# --- PROJECT SETTINGS ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- LOCALIZATION ---
# Language for the final output (e.g., en, vi, fr)
OUTPUT_LANGUAGE=en
