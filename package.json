{
  "name": "gemini-kit",
  "version": "1.0.0",
  "description": "Multi-agent AI development framework for Gemini CLI",
  "bin": {
    "gk": "./src/commands/gk.js"
  },
  "pkg": {
    "assets": [
      ".gemini/**/*",
      "src/**/*",
      "GEMINI.md"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "build": "pkg .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "src/",
    ".gemini/",
    "GEMINI.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hieund-it/geminikit.git"
  },
  "keywords": [
    "gemini",
    "ai",
    "cli",
    "agents",
    "multi-agent"
  ],
  "dependencies": {
    "commander": "^12.0.0",
    "fs-extra": "^11.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
